<style>
    body { font-family: 'Georgia', serif; padding: 50px; line-height: 1.5; color: #222; }
    .header { text-align: center; border-bottom: 2px double #333; padding-bottom: 10px; margin-bottom: 20px; }
    .name { font-size: 28px; font-weight: bold; text-transform: uppercase; }
    .section-title { font-variant: small-caps; font-weight: bold; border-bottom: 1px solid #333; margin-top: 20px; font-size: 18px; }
    .entry { margin-top: 10px; }
    .entry-header { display: flex; justify-content: space-between; font-weight: bold; }
</style>
<div class="header">
    <div class="name"><%= personal_info.full_name %></div>
    <div><%= personal_info.email %> | <%= personal_info.phone %> | <%= personal_info.location %></div>
</div>
<div class="section-title">Education</div>
<% education.forEach(edu => { %>
    <div class="entry">
        <div class="entry-header"><span><%= edu.university %></span><span><%= edu.graduation_year %></span></div>
        <div><%= edu.degree %> in <%= edu.major %></div>
    </div>
<% }) %>
<div class="section-title">Experience</div>
<% experience.forEach(exp => { %>
    <div class="entry">
        <div class="entry-header"><span><%= exp.company_name %></span><span><%= exp.start_date %> - <%= exp.end_date || 'Present' %></span></div>
        <div style="font-style: italic;"><%= exp.role %></div>
    </div>
<% }) %>