<style>
    body { font-family: 'Georgia', serif; padding: 50px; line-height: 1.5; color: #222; }
    .header { text-align: center; border-bottom: 2px double #333; padding-bottom: 10px; margin-bottom: 20px; }
    .name { font-size: 28px; font-weight: bold; text-transform: uppercase; margin-bottom: 5px; }
    .contact-info { font-size: 14px; color: #444; }
    .section-title { font-variant: small-caps; font-weight: bold; border-bottom: 1px solid #333; margin-top: 25px; margin-bottom: 15px; font-size: 18px; }
    .entry { margin-top: 15px; }
    .entry-header { display: flex; justify-content: space-between; font-weight: bold; font-size: 16px; }
    .entry-sub-header { font-style: italic; color: #444; margin-bottom: 5px; }
    .entry-desc { font-size: 14px; text-align: justify; margin-top: 5px; }
</style>

<div class="header">
    <div class="name"><%= personal_info.fullName %></div>
    
    <div class="contact-info">
        <%= personal_info.email %> | <%= personal_info.phone %> 
        <% if(personal_info.address){ %> | <%= personal_info.address %> <% } %>
    </div>
</div>

<div class="section-title">Education</div>
<% if(education && education.length > 0) { %>
    <% education.forEach(edu => { %>
        <div class="entry">
            <div class="entry-header">
                <span><%= edu.school %></span>
                <span><%= edu.year %></span>
            </div>
            <div><%= edu.degree %></div>
        </div>
    <% }) %>
<% } else { %>
    <p>No education details added.</p>
<% } %>

<div class="section-title">Experience</div>
<% if(experience && experience.length > 0) { %>
    <% experience.forEach(exp => { %>
        <div class="entry">
            <div class="entry-header">
                <span><%= exp.company %></span>
                <span><%= exp.startDate %> - <%= exp.endDate || 'Present' %></span>
            </div>
            
            <div class="entry-sub-header"><%= exp.title %></div>
            
            <div class="entry-desc"><%= exp.role %></div>
        </div>
    <% }) %>
<% } else { %>
    <p>No experience details added.</p>
<% } %>

<% if(skills && skills.length > 0) { %>
<div class="section-title">Skills</div>
<div class="entry">
    <%= skills.join(' • ') %>
</div>
<% } %>