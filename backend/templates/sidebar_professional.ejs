<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        * { box-sizing: border-box; }
        
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            color: #333;
            background-color: #fff;
            display: flex; /* لعمل التقسيمة عمودين */
            min-height: 100vh;
        }

        /* Sidebar Column */
        .sidebar {
            width: 30%;
            background-color: #f8f9fa;
            border-right: 1px solid #ddd;
            padding: 40px 20px;
            font-size: 14px;
        }

        /* Main Column */
        .main-content {
            width: 70%;
            padding: 40px 30px;
        }

        /* Header Styles */
        .name-title h1 {
            margin: 0;
            color: #2c3e50;
            font-size: 32px;
            text-transform: uppercase;
            line-height: 1.2;
        }
        
        .name-title h3 {
            margin: 5px 0 20px 0;
            color: #3498db;
            font-weight: normal;
            font-size: 18px;
        }

        /* Sidebar Sections */
        .sidebar-section {
            margin-bottom: 30px;
        }
        
        .sidebar-title {
            font-weight: bold;
            font-size: 14px;
            text-transform: uppercase;
            border-bottom: 2px solid #3498db;
            margin-bottom: 15px;
            padding-bottom: 5px;
            color: #2c3e50;
        }
        
        .contact-item {
            font-size: 13px;
            margin-bottom: 10px;
            word-break: break-all;
            display: flex;
            align-items: center;
        }
        
        .contact-item span { margin-right: 8px; }

        .skill-list {
            list-style: none;
            padding: 0;
            font-size: 13px;
        }
        
        .skill-list li {
            margin-bottom: 8px;
            padding-left: 10px;
            border-left: 3px solid #3498db;
            line-height: 1.4;
        }

        /* Main Content Sections */
        .main-section-title {
            font-size: 18px;
            color: #2c3e50;
            border-bottom: 1px solid #eee;
            margin: 30px 0 15px 0;
            padding-bottom: 8px;
            display: flex;
            align-items: center;
            font-weight: bold;
            text-transform: uppercase;
        }
        
        .main-section-title::before {
            content: "";
            width: 8px;
            height: 8px;
            background-color: #3498db;
            margin-right: 10px;
            display: inline-block;
        }

        .exp-item {
            margin-bottom: 25px;
        }
        
        .exp-header {
            display: flex;
            justify-content: space-between;
            font-weight: bold;
            font-size: 16px;
            color: #2c3e50;
        }
        
        .exp-sub {
            color: #3498db;
            font-size: 14px;
            margin-bottom: 8px;
            font-weight: bold;
        }
        
        .exp-date {
            font-size: 13px;
            color: #7f8c8d;
            font-weight: normal;
        }

        .description {
            font-size: 14px;
            text-align: justify;
            white-space: pre-line;
            line-height: 1.6;
            color: #444;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        
        <div class="sidebar-section">
            <div class="sidebar-title">Contact</div>
            <% if(personal_info.address) { %>
                <div class="contact-item"><span>📍</span> <%= personal_info.address %></div>
            <% } %>
            <div class="contact-item"><span>📧</span> <%= personal_info.email %></div>
            <div class="contact-item"><span>📞</span> <%= personal_info.phone %></div>
            <% if(personal_info.linkedin) { %>
                <div class="contact-item"><span>🔗</span> <%= personal_info.linkedin %></div>
            <% } %>
            <% if(personal_info.website) { %>
                <div class="contact-item"><span>🌐</span> <%= personal_info.website %></div>
            <% } %>
        </div>

        <% if(education && education.length > 0) { %>
        <div class="sidebar-section">
            <div class="sidebar-title">Education</div>
            <% education.forEach(edu => { %>
                <div style="margin-bottom: 15px;">
                    <div style="font-size: 14px; font-weight: bold;"><%= edu.degree %></div>
                    <div style="font-size: 13px;"><%= edu.school %></div>
                    <div style="font-size: 12px; color: #7f8c8d;"><%= edu.year %></div>
                </div>
            <% }); %>
        </div>
        <% } %>

        <% if(skills && skills.length > 0) { %>
        <div class="sidebar-section">
            <div class="sidebar-title">Skills</div>
            <ul class="skill-list">
                <% skills.forEach(skill => { %>
                    <li><%= skill %></li>
                <% }); %>
            </ul>
        </div>
        <% } %>
    </div>

    <div class="main-content">
        
        <div class="name-title">
            <h1><%= personal_info.fullName %></h1>
            <% if(experience && experience.length > 0) { %>
                <h3><%= experience[0].title %></h3>
            <% } %>
        </div>

        <% if(summary) { %>
            <div class="main-section-title">Professional Profile</div>
            <p class="description"><%= summary %></p>
        <% } %>

        <% if(experience && experience.length > 0) { %>
            <div class="main-section-title">Experience</div>
            <% experience.forEach(exp => { %>
                <div class="exp-item">
                    <div class="exp-header">
                        <span><%= exp.title %></span>
                        <span class="exp-date"><%= exp.startDate %> - <%= exp.endDate || 'Present' %></span>
                    </div>
                    <div class="exp-sub"><%= exp.company %></div>
                    <p class="description"><%= exp.role %></p>
                </div>
            <% }); %>
        <% } %>

        <% if(typeof projects !== 'undefined' && projects.length > 0) { %>
            <div class="main-section-title">Projects</div>
            <% projects.forEach(proj => { %>
                <div class="exp-item">
                    <div class="exp-header">
                        <span><%= proj.name %></span>
                    </div>
                    <p class="description"><%= proj.description %></p>
                </div>
            <% }); %>
        <% } %>

    </div>

</body>
</html>