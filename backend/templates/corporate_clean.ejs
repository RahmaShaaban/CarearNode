<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: 'Helvetica', Arial, sans-serif; padding: 0; margin: 0; display: flex; color: #333; }
        
        /* الشريط الجانبي الملون */
        .accent-bar { 
            width: 15px; 
            background: <%= (typeof template_settings !== 'undefined' && template_settings.color) ? template_settings.color : '#2c3e50' %>; 
            height: 100vh; 
            position: fixed; 
            top: 0; left: 0;
        }
        
        .main-content { margin-left: 40px; padding: 50px; width: 100%; max-width: 800px; }
        
        .name { font-size: 35px; font-weight: 800; color: #2c3e50; margin: 0; line-height: 1.2; text-transform: uppercase; }
        
        .job-label { 
            color: <%= (typeof template_settings !== 'undefined' && template_settings.color) ? template_settings.color : '#2c3e50' %>; 
            font-weight: bold; 
            letter-spacing: 2px; 
            margin-bottom: 5px;
            font-size: 14px;
        }
        
        .section-h { 
            text-transform: uppercase; 
            color: #95a5a6; 
            border-bottom: 1px solid #eee; 
            padding-bottom: 5px; 
            margin-top: 30px; 
            margin-bottom: 15px;
            font-size: 14px; 
            font-weight: bold;
            letter-spacing: 1px;
        }
        
        .contact-line { font-size: 14px; color: #555; margin-bottom: 20px; }
        
        /* تنسيق عناصر الخبرة والتعليم */
        .entry { margin-bottom: 20px; }
        .entry-title { font-weight: bold; font-size: 16px; color: #2c3e50; }
        .entry-subtitle { font-size: 14px; color: #7f8c8d; margin-bottom: 5px; }
        .entry-desc { font-size: 14px; line-height: 1.6; color: #444; margin-top: 5px; }
    </style>
</head>
<body>

<div class="accent-bar"></div>

<div class="main-content">
    
    <div class="job-label">CURRICULUM VITAE</div>
    <h1 class="name"><%= personal_info.fullName %></h1>
    
    <div class="contact-line">
        <%= personal_info.email %> | <%= personal_info.phone %>
        <% if(personal_info.address) { %> | <%= personal_info.address %> <% } %>
        <% if(personal_info.linkedin) { %> | <%= personal_info.linkedin %> <% } %>
    </div>

    <p style="line-height: 1.6; color: #555;"><%= summary %></p>

    <% if(experience && experience.length > 0) { %>
    <div class="section-h">Experience</div>
    <% experience.forEach(exp => { %>
        <div class="entry">
            <div class="entry-title"><%= exp.title %> <span style="font-weight: normal; color: #555;">at <%= exp.company %></span></div>
            
            <div class="entry-subtitle"><%= exp.startDate %> - <%= exp.endDate || 'Present' %></div>
            
            <div class="entry-desc"><%= exp.role %></div>
        </div>
    <% }) %>
    <% } %>

    <% if(education && education.length > 0) { %>
    <div class="section-h">Education</div>
    <% education.forEach(edu => { %>
        <div class="entry">
            <div class="entry-title"><%= edu.degree %></div>
            <div class="entry-subtitle">
                <%= edu.school %> | <span><%= edu.year %></span>
            </div>
        </div>
    <% }) %>
    <% } %>

    <% if(skills && skills.length > 0) { %>
    <div class="section-h">Key Expertise</div>
    <p style="line-height: 1.8;">
        <%= skills.join(' • ') %>
    </p>
    <% } %>

</div>

</body>
</html>