<style>
    body { font-family: 'Helvetica', Arial, sans-serif; padding: 0; margin: 0; display: flex; }
    .accent-bar { width: 15px; background: <%= template_settings?.color || '#2c3e50' %>; height: 100vh; position: fixed; }
    .main-content { margin-left: 40px; padding: 50px; width: 100%; }
    .name { font-size: 35px; font-weight: 800; color: #2c3e50; margin: 0; }
    .job-label { color: <%= template_settings?.color || '#2c3e50' %>; font-weight: bold; letter-spacing: 2px; }
    .section-h { text-transform: uppercase; color: #95a5a6; border-bottom: 1px solid #eee; padding-bottom: 5px; margin-top: 30px; font-size: 14px; }
</style>
<div class="accent-bar"></div>
<div class="main-content">
    <div class="job-label">CURRICULUM VITAE</div>
    <h1 class="name"><%= personal_info.full_name %></h1>
    <p><%= summary %></p>
    <div class="section-h">Contact Details</div>
    <p><%= personal_info.email %> / <%= personal_info.phone %></p>
    <div class="section-h">Key Expertise</div>
    <p><%= skills.join(' • ') %></p>
</div>