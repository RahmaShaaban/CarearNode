<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        :root {
            /* الألوان الديناميكية */
            --main-text: #333333;
            /* استخدام اللون المختار أو الأزرق الغامق كاحتياطي */
            --section-header: <%= (typeof template_settings !== 'undefined' && template_settings.color) ? template_settings.color : '#003366' %>; 
            --sub-text: #555555;
            --line-color: #eeeeee;
        }
        body {
            font-family: '<%= (typeof template_settings !== 'undefined' && template_settings.font) ? template_settings.font : "Arial, Helvetica, sans-serif" %>', sans-serif;
            line-height: 1.6;
            color: var(--main-text);
            margin: 0;
            padding: 40px;
        }
        .name-header { text-align: left; margin-bottom: 15px; }
        .name-header h1 { 
            margin: 0; 
            font-size: 32px; 
            text-transform: uppercase;
            color: var(--section-header); 
            letter-spacing: 1px;
        }
        
        .contact-bar {
            font-size: 13px;
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            border-bottom: 2px solid var(--section-header);
            padding-bottom: 15px;
            margin-bottom: 25px;
            color: var(--sub-text);
        }
        
        .section-label {
            font-size: 16px;
            font-weight: bold;
            color: var(--section-header);
            text-transform: uppercase;
            background: #f4f4f4;
            padding: 8px 12px;
            margin-top: 25px;
            margin-bottom: 15px;
            border-left: 4px solid var(--section-header);
        }
        
        .summary-text { font-size: 14px; text-align: justify; margin: 0; color: #444; }
        
        /* تنسيق الخبرة والتعليم */
        .item-block { margin-bottom: 20px; page-break-inside: avoid; }
        
        .item-top-row { 
            display: flex; 
            justify-content: space-between; 
            align-items: baseline;
            margin-bottom: 2px;
        }
        
        .job-title { font-weight: bold; font-size: 16px; color: #222; }
        .job-date { font-weight: bold; font-size: 14px; color: var(--section-header); }
        
        .item-sub-row { 
            font-style: italic; 
            font-size: 14px; 
            color: var(--sub-text); 
            margin-bottom: 8px;
        }
        
        .job-desc { font-size: 14px; color: #444; line-height: 1.5; }

        /* تنسيق المهارات */
        .skills-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }
        .skill-item { 
            font-size: 13px; 
            background: #fff;
            border: 1px solid #ddd;
            padding: 5px 10px;
            border-radius: 4px;
        }
    </style>
</head>
<body>

    <div class="name-header">
        <h1><%= personal_info.fullName %></h1>
    </div>

    <div class="contact-bar">
        <span>📧 <%= personal_info.email %></span>
        <span>📞 <%= personal_info.phone %></span>
        <% if(personal_info.address) { %> <span>📍 <%= personal_info.address %></span> <% } %>
        <% if(personal_info.linkedin) { %> <span>🔗 LinkedIn</span> <% } %>
        <% if(personal_info.website) { %> <span>🌐 Portfolio</span> <% } %>
    </div>

    <% if(summary) { %>
        <div class="section-label">Professional Summary</div>
        <p class="summary-text"><%= summary %></p>
    <% } %>

    <% if(skills && skills.length > 0) { %>
        <div class="section-label">Technical Skills</div>
        <div class="skills-grid">
            <% skills.forEach(skill => { %>
                <span class="skill-item"><%= skill %></span>
            <% }); %>
        </div>
    <% } %>

    <% if(experience && experience.length > 0) { %>
        <div class="section-label">Work Experience</div>
        <% experience.forEach(exp => { %>
            <div class="item-block">
                <div class="item-top-row">
                    <span class="job-title"><%= exp.title %></span>
                    <span class="job-date"><%= exp.startDate %> – <%= exp.endDate || 'Present' %></span>
                </div>
                
                <div class="item-sub-row">
                    <%= exp.company %>
                </div>
                
                <div class="job-desc">
                    <%= exp.role %>
                </div>
            </div>
        <% }); %>
    <% } %>

    <% if(education && education.length > 0) { %>
        <div class="section-label">Education</div>
        <% education.forEach(edu => { %>
            <div class="item-block">
                <div class="item-top-row">
                    <span class="job-title"><%= edu.degree %></span>
                    <span class="job-date"><%= edu.year %></span>
                </div>
                <div class="item-sub-row">
                    <%= edu.school %>
                </div>
            </div>
        <% }); %>
    <% } %>

</body>
</html>