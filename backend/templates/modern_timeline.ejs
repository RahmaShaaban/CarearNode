<style>
    body { font-family: 'Lato', sans-serif; padding: 40px; color: #444; }
    .timeline { position: relative; margin: 20px 0; padding-left: 40px; }
    .timeline::before { content: ''; position: absolute; left: 10px; top: 0; width: 2px; height: 100%; background: #eee; }
    .timeline-node { position: relative; margin-bottom: 30px; }
    .timeline-node::after { content: ''; position: absolute; left: -36px; top: 5px; width: 14px; height: 14px; background: <%= template_settings?.color || '#00b894' %>; border-radius: 50%; border: 4px solid #fff; box-shadow: 0 0 5px rgba(0,0,0,0.1); }
    .date-tag { font-size: 12px; font-weight: bold; color: <%= template_settings?.color || '#00b894' %>; }
    .company-name { font-weight: bold; color: #222; }
</style>
<h1><%= personal_info.full_name %></h1>
<p><%= summary %></p>
<div class="timeline">
    <% experience.forEach(exp => { %>
        <div class="timeline-node">
            <div class="date-tag"><%= exp.start_date %> - <%= exp.end_date || 'Present' %></div>
            <div class="company-name"><%= exp.company_name %></div>
            <div class="role-text"><%= exp.role %></div>
        </div>
    <% }) %>
</div>