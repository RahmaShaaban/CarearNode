<style>
    .bold-header { background: <%= template_settings?.color || '#e74c3c' %>; color: white; padding: 50px; }
    .main-body { padding: 40px; display: grid; grid-template-columns: 1fr 2fr; gap: 30px; }
</style>
<div class="bold-header">
    <h1><%= personal_info.full_name %></h1>
    <h2><%= experience[0]?.role %></h2>
</div>
<div class="main-body">
    <div><h3>Skills</h3><ul><% skills.forEach(s => { %><li><%= s %></li><% }) %></ul></div>
    <div><h3>Summary</h3><p><%= summary %></p></div>
</div>